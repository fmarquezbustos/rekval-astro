---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const socios = [
  { image: "/images/socios/socio6.webp", name: "Socio 6", role: "Socio principal" },
  { image: "/images/socios/socio5.webp", name: "Socio 5", role: "Socia principal" },
  { image: "/images/socios/socio4.webp", name: "Socio 4", role: "Socia principal" },
  { image: "/images/socios/socio3.webp", name: "Socio 3", role: "Socio" },
  { image: "/images/socios/socio2.webp", name: "Socio 2", role: "Socio" },
  { image: "/images/socios/socio1.webp", name: "Socio 1", role: "Socio" },
];

const filosofia = [
  {
    title: "Mirada integral",
    text: "Entendemos el patrimonio como un sistema: personas, familia, empresa, inversión, protección y activos reales.",
  },
  {
    title: "Criterio antes que producto",
    text: "Cada recomendación debe responder a una necesidad concreta y a una estrategia comprensible para el cliente.",
  },
  {
    title: "Relación de largo plazo",
    text: "Acompañamos decisiones que evolucionan junto con las etapas personales, familiares y empresariales.",
  },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Quiénes Somos | REKVAL</title>
  </head>

  <body>
    <Header />

    <main>
      <section class="about-hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <span class="section-label">Quiénes somos</span>
            <h1>Una marca matriz para ordenar decisiones patrimoniales con visión de largo plazo.</h1>
            <p>
              REKVAL reúne experiencia financiera, patrimonial, internacional e
              inmobiliaria para acompañar a personas, familias y empresas desde una
              mirada integrada.
            </p>
          </div>

          <div class="hero-panel">
            <span>REKVAL</span>
            <strong>Una marca. Distintas áreas de especialización.</strong>
          </div>
        </div>
      </section>

      <section class="intro-band">
        <div class="container intro-layout">
          <div>
            <span class="section-label">Nuestra forma de mirar</span>
            <h2>Construir patrimonio no es acumular productos: es tomar decisiones coherentes.</h2>
          </div>

          <div class="intro-copy">
            <p>
              Creemos que una estrategia patrimonial debe partir por comprender la
              realidad de cada cliente: sus objetivos, sus prioridades, su etapa de
              vida y el tipo de decisiones que necesita tomar.
            </p>
            <p>
              Desde esa base, REKVAL conecta distintas unidades especializadas para
              entregar orientación, implementación y seguimiento con un criterio
              común.
            </p>
          </div>
        </div>
      </section>

      <section class="partners-section">
        <div class="container">
          <div class="section-heading">
            <span class="section-label">Socios</span>
            <h2>Un equipo con experiencia complementaria para abordar el patrimonio desde distintos ángulos.</h2>
          </div>

          <div class="partners-grid">
            {socios.map((socio) => (
              <article class="partner-card">
                <div class="partner-image">
                  <img src={socio.image} alt={`Retrato de ${socio.name}`} />
                </div>
                <span>{socio.role}</span>
                <h3>{socio.name}</h3>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="philosophy-section">
        <div class="container philosophy-grid">
          <div class="philosophy-heading">
            <span class="section-label">Nuestra filosofía</span>
            <h2>Claridad, especialización y acompañamiento permanente.</h2>
            <p>
              Nuestro trabajo busca que cada decisión tenga un propósito dentro de
              una planificación patrimonial mayor.
            </p>
          </div>

          <div class="philosophy-list">
            {filosofia.map((item, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #07111f;
    color: #ffffff;
  }

  :global(img) {
    max-width: 100%;
    display: block;
  }

  .container {
    width: min(1120px, 92%);
    margin: 0 auto;
  }

  .section-label {
    display: inline-block;
    margin-bottom: 18px;
    color: #8fd3ff;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .about-hero {
    position: relative;
    overflow: hidden;
    padding: 170px 0 110px;
    background:
      radial-gradient(circle at 82% 18%, rgba(11, 122, 117, 0.24), transparent 32%),
      linear-gradient(135deg, #07111f 0%, #102a43 58%, #0b2f44 100%);
  }

  .about-hero::after {
    content: "";
    position: absolute;
    right: -180px;
    bottom: -220px;
    width: 560px;
    height: 560px;
    border-radius: 999px;
    background: rgba(143, 211, 255, 0.1);
    filter: blur(22px);
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 72px;
    align-items: end;
  }

  .hero-copy h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(42px, 5.8vw, 72px);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .hero-copy p {
    max-width: 680px;
    margin: 30px 0 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 19px;
    line-height: 1.75;
  }

  .hero-panel {
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 42px;
    border-radius: 36px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04)),
      radial-gradient(circle at 76% 18%, rgba(143, 211, 255, 0.22), transparent 34%);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 34px 100px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(18px);
  }

  .hero-panel span {
    margin-bottom: 18px;
    color: #8fd3ff;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .hero-panel strong {
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .intro-band,
  .partners-section {
    background: #f3f5f4;
    color: #102a43;
  }

  .intro-band {
    padding: 110px 0;
  }

  .intro-layout {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 72px;
  }

  .intro-layout .section-label,
  .partners-section .section-label,
  .philosophy-section .section-label {
    color: #0b7a75;
  }

  h2 {
    margin: 0;
    font-size: clamp(36px, 5vw, 58px);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .intro-copy p {
    margin: 0 0 24px;
    color: rgba(16, 42, 67, 0.7);
    font-size: 18px;
    line-height: 1.75;
  }

  .intro-copy p:last-child {
    margin-bottom: 0;
  }

  .partners-section {
    padding: 120px 0;
  }

  .section-heading {
    max-width: 900px;
    margin-bottom: 66px;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
  }

  .partner-card {
    min-height: 420px;
    padding: 34px;
    border-radius: 30px;
    background: #ffffff;
    border: 1px solid rgba(16, 42, 67, 0.08);
    box-shadow: 0 24px 70px rgba(16, 42, 67, 0.08);
    text-align: center;
  }

  .partner-image {
    width: min(240px, 86%);
    aspect-ratio: 1;
    margin: 0 auto 32px;
    border-radius: 999px;
    overflow: hidden;
    border: 2px solid rgba(11, 122, 117, 0.62);
    background: #102a43;
  }

  .partner-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .partner-card span {
    display: block;
    margin-bottom: 12px;
    color: #0b7a75;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .partner-card h3 {
    margin: 0;
    color: #102a43;
    font-size: 28px;
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .philosophy-section {
    padding: 120px 0;
    background: #ffffff;
    color: #102a43;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 72px;
    align-items: start;
  }

  .philosophy-heading p {
    max-width: 560px;
    margin: 26px 0 0;
    color: rgba(16, 42, 67, 0.68);
    font-size: 18px;
    line-height: 1.75;
  }

  .philosophy-list {
    display: grid;
    gap: 18px;
  }

  .philosophy-list article {
    padding: 30px;
    border-radius: 28px;
    background: #f3f5f4;
    border: 1px solid rgba(16, 42, 67, 0.08);
  }

  .philosophy-list span {
    display: block;
    margin-bottom: 18px;
    color: #0b7a75;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.14em;
  }

  .philosophy-list h3 {
    margin: 0;
    color: #102a43;
    font-size: 28px;
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .philosophy-list p {
    margin: 16px 0 0;
    color: rgba(16, 42, 67, 0.68);
    font-size: 16px;
    line-height: 1.65;
  }

  @media (max-width: 960px) {
    .hero-grid,
    .intro-layout,
    .philosophy-grid {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .partners-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .about-hero {
      padding: 132px 0 76px;
    }

    .hero-copy h1 {
      font-size: clamp(36px, 10vw, 46px);
    }

    .hero-panel {
      min-height: 260px;
      padding: 30px;
    }

    .hero-panel strong {
      font-size: clamp(30px, 9vw, 42px);
    }

    .intro-band,
    .partners-section,
    .philosophy-section {
      padding: 84px 0;
    }

    .partners-grid {
      grid-template-columns: 1fr;
    }

    .partner-card {
      min-height: auto;
      padding: 30px 24px;
    }
  }
</style>
